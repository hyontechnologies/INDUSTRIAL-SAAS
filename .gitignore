# ──────────────────────────────────────────────────────────────────────────
# Piccadily Industrial Historian — .gitignore
# ──────────────────────────────────────────────────────────────────────────

# ── Environment & Secrets ────────────────────────────────────────────────
.env
.env.local
.env.*.local
!.env.example
*.pem
*.key
*.crt
nginx/ssl/

# ── Python ───────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
*.egg
dist/
build/
.eggs/
.venv/
venv/
env/
.Python
pip-log.txt
pip-delete-this-directory.txt
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
.hypothesis/
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.pdf
# ── Node.js / Frontend ──────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/
frontend/dist/
frontend/.vite/

# ── Docker ───────────────────────────────────────────────────────────────
docker-compose.override.yml

# ── IDE / Editor ─────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.project
.settings/
.classpath
*.sublime-workspace
*.sublime-project

# ── OS ───────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db

# ── Database / Local State ───────────────────────────────────────────────
*.db
*.sqlite
*.sqlite3
edge_cursor.db
tsdb_data/

# ── Logs ─────────────────────────────────────────────────────────────────
*.log
logs/

# ── Grafana local data ──────────────────────────────────────────────────
grafana/data/
edge-agent/*.db*
edge-agent/*.db-wal
edge-agent/*.db-shm
