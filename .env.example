# ═══════════════════════════════════════════════════════════════════
# Piccadily Industrial Historian — Environment Variables Template
# Copy to .env and fill in your values
# ═══════════════════════════════════════════════════════════════════

# ── Database ──────────────────────────────────────────────────────
DB_PASSWORD=historian_dev_password
DATABASE_URL=postgresql://historian_user:historian_dev_password@timescaledb:5432/historian

# ── Supabase Auth ─────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_JWT_SECRET=your-jwt-secret-from-supabase-dashboard
SUPABASE_ANON_KEY=your-anon-key-from-supabase-dashboard

# ── Edge API Keys ─────────────────────────────────────────────────
EDGE_API_KEYS=

# ── CORS ──────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost

# ── Grafana ───────────────────────────────────────────────────────
GRAFANA_ADMIN_PASSWORD=grafana_dev
GRAFANA_READER_PW=grafana_reader_dev

# ── Frontend (Vite) ──────────────────────────────────────────────
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ── Edge Agent (runs externally) ─────────────────────────────────
EDGE_API_KEY_RAW=changeme
OPC_URL=opc.tcp://127.0.0.1:4840/piccadily/
PLANT_ID=PICCADILY_PLANT_01
TENANT_ID=piccadily
